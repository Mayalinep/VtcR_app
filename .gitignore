# VTC Rachel - Root .gitignore
# Ce fichier ignore les fichiers à la racine du projet (hors app/)

# Documentation générée
*.log

# macOS metadata files
._*
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.temp

# Le dossier app/ a son propre .gitignore pour Next.js
.claude/
